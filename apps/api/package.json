{
  "name": "@universal-healthcare/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "build": "dotenv -e .env.example -- prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "dotenv -e .env.example -- prisma generate && eslint src",
    "typecheck": "dotenv -e .env.example -- prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "dotenv -e .env.test -- prisma generate && dotenv -e .env.test -- prisma db push --skip-generate --accept-data-loss && dotenv -e .env.test -- vitest run",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "db:reset": "dotenv -e .env -- prisma db push --force-reset --accept-data-loss && dotenv -e .env -- prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^8",
    "@universal-healthcare/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
