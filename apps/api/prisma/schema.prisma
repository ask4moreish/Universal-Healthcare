generator client {
  provider = "prisma-client-js"
  seed     = "tsx prisma/seed.ts"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  emailVerified         Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  creatorProfile        CreatorProfile?
  fanProfile            FanProfile?
  refreshTokens         RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  playlists             Playlist[]
  comments              Comment[]
  followedBy            Follow[]   @relation("FollowFollower")
  following             Follow[]   @relation("FollowFollowee")
  recipientNotifications Notification[] @relation("NotificationRecipient")
  actorNotifications    Notification[] @relation("NotificationActor")
}

// Notifications: a user receives one when others follow them or reply to
// their comments.
//
// Asymmetric delete behavior on purpose:
//   recipient -> Cascade : the recipient's account is gone, so any
//                         notification they haven't read has no audience.
//   actor     -> SetNull  : the actor's account can disappear without
//                         nuking the recipient's notification history. The
//                         notification row stays, becoming system-attributed
//                         (`actorId: null`); the `type` + `entityType` +
//                         `entityId` still say WHAT happened, just not
//                         by whom.
//
// Note: SQLite requires `PRAGMA foreign_keys = ON` for these ON DELETE
// rules to fire at runtime; Prisma enables it by default for the standard
// client. If a future contributor configures a custom Prisma client (say
// for a benchmark or k6 load test) and disables the pragma, the schema's
// stated behavior will silently diverge from what
// `notification.service.test.ts` `delete semantics` tests expect.
model Notification {
  id           String   @id @default(cuid())
  recipientId  String
  actorId      String?
  recipient    User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor        User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type         String
  entityType   String
  entityId     String
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Composite supports the inbox query: WHERE recipientId = ? AND read = ?
  // ORDER BY createdAt DESC. SQLite uses the leading column for equality; the
  // boolean filter narrows further; the index serves the ORDER BY (descending
  // read on an ascending index is a reverse scan — fine).
  @@index([recipientId, read, createdAt])
}

// Follows: a user-to-user one-way relationship. Each row represents
// `follower.following(followee)`. @@unique enforces that any (follower, followee)
// pair can only exist once — creating a duplicate returns Prisma's P2002, which
// the service maps to a 409 ALREADY_FOLLOWING.
model Follow {
  id         String   @id @default(cuid())
  followerId String
  followeeId String
  follower   User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User     @relation("FollowFollowee", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Composite unique: a user can only follow another user once.
  // Prisma generates the index name `followerId_followeeId` from this.
  @@unique([followerId, followeeId])
  // Reverse-lookup index: who is following this user?
  @@index([followeeId])
}

model Playlist {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  isPublic  Boolean   @default(false)
  tracks    Track[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Track {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  title      String
  artist     String
  duration   Int
  position   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([playlistId])
}

// Comments: threaded at one level (parent -> replies[]). Cascade-deletes
// are intentional across User and Playlist boundaries — orphan rows would
// serve no purpose.
model Comment {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlistId String
  playlist   Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  body       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Postgres + SQLite: composite index supports "WHERE playlistId = ? ORDER BY
  // createdAt" with a reverse scan (ascending index also serves DESC ORDER BY).
  @@index([playlistId, createdAt])
  @@index([parentId])
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  slug        String   @unique
  bio         String?
  avatarUrl   String?
  genre       String?
  location    String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FanProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  avatarUrl   String?
  genrePrefs  String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RefreshToken {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String   @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  replacedById  String?  @unique
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
